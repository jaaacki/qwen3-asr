# ==========================================
# Qwen3-ASR Configuration
# ==========================================
# Copy to .env and adjust as needed.

# -----------------
# Host / Network
# -----------------
# External port exposed on the host machine (maps to container port 8000)
PORT=8100

# -----------------
# Core
# -----------------
# HuggingFace model ID (Qwen/Qwen3-ASR-0.6B for speed, 1.7B for accuracy)
MODEL_ID=Qwen/Qwen3-ASR-1.7B
# Seconds before unloading model from GPU (0 = keep loaded forever)
IDLE_TIMEOUT=1800
# Max seconds per inference request before timeout
REQUEST_TIMEOUT=300

# -----------------
# Logging
# -----------------
# Log verbosity: trace · debug · info · warning · error · critical (default: info)
LOG_LEVEL=info

# -----------------
# WebSocket Streaming
# -----------------
# WS_BUFFER_SIZE=14400         # Bytes before triggering transcription (~450ms at 16kHz)
# WS_FLUSH_SILENCE_MS=600     # Silence padding on flush/disconnect (ms)
WS_WINDOW_MAX_S=6.0           # Sliding window: max seconds of context (higher = better accuracy, more GPU)
ASR_USE_SERVER_VAD=true        # Server-side VAD: auto-flush on speech→silence, skip inference for silence
                               # Clients can override per-connection via ?use_server_vad=false query param
                               # or mid-session via {"action":"config","use_server_vad":false}

# -----------------
# Subtitle Aligner
# -----------------
# Loaded on first /v1/audio/subtitles?mode=accurate call (~5.8GB VRAM)
FORCED_ALIGNER_ID=Qwen/Qwen3-ForcedAligner-0.6B

# -----------------
# Subtitle Timing
# -----------------
# SUBTITLE_MAX_DURATION=7.0       # Max duration per subtitle block (seconds)
# SUBTITLE_PAUSE_THRESHOLD=0.5    # Pause duration that triggers subtitle break (seconds)
# SUBTITLE_MIN_DURATION=0.833     # Minimum subtitle display time (seconds)
# SUBTITLE_MIN_GAP=0.083          # Minimum gap between subtitles (seconds)

# -----------------
# Translation (OpenAI-compatible API)
# -----------------
# Works with Ollama Cloud, local Ollama, vLLM, or OpenAI.
# Ollama Cloud: https://ollama.com/api
# Local Ollama: http://localhost:11434/v1
# OpenAI:       https://api.openai.com/v1
OPENAI_BASE_URL=https://ollama.com/api
OPENAI_API_KEY=your_api_key_here
TRANSLATE_MODEL=gemma3:12b

# -----------------
# Translation Tuning
# -----------------
# TRANSLATE_TEMPERATURE=0.3       # LLM temperature for text translation
# TRANSLATE_SRT_TEMPERATURE=0.1   # LLM temperature for SRT translation (lower = more faithful)

# -----------------
# SSE Streaming
# -----------------
# SSE_CHUNK_SECONDS=5             # Duration of each SSE chunk (seconds)
# SSE_OVERLAP_SECONDS=1           # Overlap between SSE chunks (seconds)

# -----------------
# Quantization
# -----------------
# QUANTIZE=int8   # bitsandbytes W8A8 (~50% VRAM reduction)
# QUANTIZE=fp8    # torchao (requires sm_89+ Hopper/Ada)
QUANTIZE=
USE_CUDA_GRAPHS=false

# -----------------
# Dual Model / Speculative Decoding
# -----------------
DUAL_MODEL=false
FAST_MODEL_ID=Qwen/Qwen3-ASR-0.6B
USE_SPECULATIVE=false

# -----------------
# Encoder Acceleration (opt-in)
# -----------------
ONNX_ENCODER_PATH=
TRT_ENCODER_PATH=

# -----------------
# Infrastructure
# -----------------
GATEWAY_MODE=true
# NUMA_NODE=0
USE_GRANIAN=false
WORKER_HOST=127.0.0.1
WORKER_PORT=8001

# -----------------
# Docker / CUDA Internals
# -----------------
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
